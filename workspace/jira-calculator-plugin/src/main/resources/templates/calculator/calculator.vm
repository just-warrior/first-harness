<html>
<head>
    <title>$i18n.getText("page.title")</title>
    <meta name="decorator" content="atl.admin"/>
    <meta name="admin.active.section" content="admin_plugins_menu/calculator-section"/>
    $webResourceManager.requireResource("${atlassian.plugin.key}:calculator-resources")
</head>
<body>
<section id="content" role="main">
    <header class="aui-page-header">
        <div class="aui-page-header-inner">
            <div class="aui-page-header-main">
                <h1>$i18n.getText("page.title")</h1>
            </div>
        </div>
    </header>

    <div class="aui-page-panel">
        <div class="aui-page-panel-inner">
            <div class="aui-page-panel-content">

                <div id="calculator-wrapper">
                    <form class="aui" id="calculator-form" onsubmit="return false;">
                        <input class="text"
                               type="text"
                               id="calc-display"
                               readonly="readonly"
                               value=""
                               placeholder="0"/>
                    </form>

                    <div class="calc-grid">
                        <button class="aui-button calc-btn btn-clear">C</button>
                        <button class="aui-button calc-btn btn-op" data-op="/">÷</button>
                        <button class="aui-button calc-btn btn-op" data-op="*">×</button>
                        <button class="aui-button calc-btn btn-op btn-backspace">⌫</button>

                        <button class="aui-button calc-btn btn-num">7</button>
                        <button class="aui-button calc-btn btn-num">8</button>
                        <button class="aui-button calc-btn btn-num">9</button>
                        <button class="aui-button calc-btn btn-op" data-op="-">−</button>

                        <button class="aui-button calc-btn btn-num">4</button>
                        <button class="aui-button calc-btn btn-num">5</button>
                        <button class="aui-button calc-btn btn-num">6</button>
                        <button class="aui-button calc-btn btn-op" data-op="+">+</button>

                        <button class="aui-button calc-btn btn-num">1</button>
                        <button class="aui-button calc-btn btn-num">2</button>
                        <button class="aui-button calc-btn btn-num">3</button>
                        <button class="aui-button aui-button-primary calc-btn btn-equals btn-equals-tall">=</button>

                        <button class="aui-button calc-btn btn-num btn-zero">0</button>
                        <button class="aui-button calc-btn btn-op">.</button>
                    </div>
                </div>

                <div id="history-panel">
                    <h3>$i18n.getText("calculator.history.title")</h3>
                    <ul id="history-list">
                        <li class="history-empty">$i18n.getText("calculator.history.empty")</li>
                    </ul>
                </div>

            </div>
        </div>
    </div>
</section>
</body>
</html>
