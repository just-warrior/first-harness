<html>
<head>
    <title>$i18n.getText("page.title") - Error</title>
    <meta name="decorator" content="atl.admin"/>
    <meta name="admin.active.section" content="admin_plugins_menu/calculator-section"/>
</head>
<body>
<section id="content" role="main">
    <header class="aui-page-header">
        <div class="aui-page-header-inner">
            <div class="aui-page-header-main">
                <h1>$i18n.getText("page.title")</h1>
            </div>
        </div>
    </header>

    <div class="aui-page-panel">
        <div class="aui-page-panel-inner">
            <div class="aui-page-panel-content">

                <div class="aui-message aui-message-error">
                    <p class="title"><strong>Error</strong></p>
                    #if($errorMessages && $errorMessages.size() > 0)
                        #foreach($msg in $errorMessages)
                            <p>$msg</p>
                        #end
                    #else
                        <p>An unexpected error occurred. Please try again.</p>
                    #end
                </div>

                <p>
                    <a href="/secure/CalculatorAction!default.jspa" class="aui-button">Return to Calculator</a>
                </p>

            </div>
        </div>
    </div>
</section>
</body>
</html>
